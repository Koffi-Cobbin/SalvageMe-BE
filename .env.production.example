# Template for a STAGING or PRODUCTION `.env` — copy this one on a server,
# not `.env.example` (which is tuned for zero-setup local dev and will
# silently misconfigure a real deployment if used as-is: SQLite instead of
# Postgres, localhost CORS origins, etc.).
#
# Every value below needs to be filled in for real before this is usable —
# nothing here is a safe "just works" default the way .env.example's values
# are for local dev.

DJANGO_SECRET_KEY=
# Do NOT set DJANGO_SETTINGS_MODULE here if your WSGI file already hard-
# assigns it (`os.environ["DJANGO_SETTINGS_MODULE"] = "config.settings.prod"`)
# — see README "Deploying to PythonAnywhere" for why a value here can
# silently win over the WSGI file's setdefault()-free assignment, or match
# them if you're intentionally overriding.

# --- Database: PostgreSQL + PostGIS is required outside local dev ----------
# config/settings/prod.py and staging.py both refuse to boot on anything
# other than "postgis" here, on purpose.
DB_ENGINE=postgis
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# --- CORS --------------------------------------------------------------
# Your actual deployed frontend origin(s), comma-separated. NOT localhost.
CORS_ALLOWED_ORIGINS=

# --- FileForge (file storage — server-to-server only) -----------------------
FILEFORGE_BASE_URL=
FILEFORGE_API_KEY=

# --- Email ---------------------------------------------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# --- Required in staging/prod: your actual deployed hostname, bare (no
# scheme, no path) — e.g. "salvageme.pythonanywhere.com" -------------------
ALLOWED_HOSTS=

# --- Business-rule tuning (optional, sensible defaults in base.py) --------
PENDING_REQUEST_EXPIRY_DAYS=14
EXCHANGE_REMINDER_WINDOW_HOURS=24
