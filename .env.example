# Copy this file to `.env` for LOCAL DEVELOPMENT ONLY. Never commit the
# real `.env` — it's already in .gitignore.
#
# Deploying to staging/production? Use `.env.production.example` instead —
# the defaults below (SQLite, localhost CORS origins) are convenient for
# local dev but will silently misconfigure a real deployment if copied
# as-is.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DJANGO_SETTINGS_MODULE is deliberately NOT set here. manage.py defaults to
# config.settings.dev locally, and the WSGI/ASGI entrypoints
# (config/wsgi.py, config/asgi.py) default to config.settings.prod — both
# via os.environ.setdefault(), so leaving this unset lets each context pick
# its own correct default. If you DO set it explicitly (e.g. in a real .env
# on a server), make sure it matches that environment — a .env with
# DJANGO_SETTINGS_MODULE=config.settings.dev deployed to production will
# silently force dev settings (DEBUG=True, permissive ALLOWED_HOSTS) even
# if the WSGI file itself tries to set config.settings.prod, because
# setdefault() never overrides a value that's already present.

# --- Database (PostgreSQL + PostGIS, or SQLite for local dev) --------------
# "spatialite" (SQLite + the SpatiaLite extension) is dev.py's default —
# zero setup, no DB server to run, still supports geo search. Set this to
# "postgis" to use a real PostgreSQL+PostGIS instance instead (staging.py
# and prod.py always use postgis regardless of this value). See README ->
# "Local setup" for the two options side by side.
DB_ENGINE=spatialite

# Uncomment/edit these only if DB_ENGINE=postgis:
# DB_NAME=salvageme
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# --- CORS --------------------------------------------------------------
# Comma-separated list of allowed frontend origins. Never use "*" outside
# local dev.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- FileForge (file storage — server-to-server only) -----------------------
# Point this at a locally-running FileForge instance (see README ->
# "FileForge local setup") or a shared dev deployment your team uses.
FILEFORGE_BASE_URL=http://localhost:9000
# FILEFORGE_API_KEY is a secret. It is NEVER returned in any API response
# and NEVER embedded in frontend code — it only lives here and inside
# common/fileforge_client.py's request headers.
FILEFORGE_API_KEY=ffk_your_dev_key_here

# --- Email (console backend is used automatically in dev.py regardless of
# these — they only matter for staging.py/prod.py) --------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@salvageme.example

# --- Staging/prod only ---------------------------------------------------
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# --- Business-rule tuning (optional, sensible defaults in base.py) --------
PENDING_REQUEST_EXPIRY_DAYS=14
EXCHANGE_REMINDER_WINDOW_HOURS=24
