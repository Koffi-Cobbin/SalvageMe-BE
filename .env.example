# Copy this file to `.env` and fill in real values for local development.
# Never commit the real `.env` — it's already in .gitignore.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Database (PostgreSQL + PostGIS) ---------------------------------------
DB_NAME=salvageme
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- CORS --------------------------------------------------------------
# Comma-separated list of allowed frontend origins. Never use "*" outside
# local dev.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- FileForge (file storage — server-to-server only) -----------------------
# Point this at a locally-running FileForge instance (see README ->
# "FileForge local setup") or a shared dev deployment your team uses.
FILEFORGE_BASE_URL=http://localhost:9000
# FILEFORGE_API_KEY is a secret. It is NEVER returned in any API response
# and NEVER embedded in frontend code — it only lives here and inside
# common/fileforge_client.py's request headers.
FILEFORGE_API_KEY=ffk_your_dev_key_here

# --- Email (console backend is used automatically in dev.py regardless of
# these — they only matter for staging.py/prod.py) --------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@salvageme.example

# --- Staging/prod only ---------------------------------------------------
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# --- Business-rule tuning (optional, sensible defaults in base.py) --------
PENDING_REQUEST_EXPIRY_DAYS=14
EXCHANGE_REMINDER_WINDOW_HOURS=24
